{
	"name": "files-progress",
	"version": "1.5.0",
	"description": "Obsidian plugin: tiny fullness progress bars in the file explorer.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"lint": "eslint .",
		"test": "vitest run",
		"check": "npm run lint && npm test && npm run build"
	},
	"keywords": [
		"obsidian",
		"plugin",
		"file-explorer",
		"progress"
	],
	"author": "Walter",
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^9.39.2",
		"@eslint/json": "0.14.0",
		"@types/node": "^20.14.0",
		"esbuild": "^0.25.0",
		"eslint": "^9.39.2",
		"eslint-plugin-obsidianmd": "^0.4.1",
		"obsidian": "1.5.7",
		"typescript": "^5.5.0",
		"typescript-eslint": "^8.64.0",
		"vitest": "^4.1.10"
	}
}
